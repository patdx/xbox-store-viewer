{
	"name": "xbox-store-viewer",
	"private": true,
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"build": "nx exec -- wrangler types && react-router build",
		"deploy": "nx exec -- wrangler deploy",
		"dev": "react-router dev",
		"start": "nx exec -- wrangler dev",
		"typecheck": "tsc",
		"typegen": "wrangler types",
		"update-react": "pnpm install --save-exact react@rc react-dom@rc",
		"lint": "biome lint",
		"lint:fix": "biome lint --fix",
		"format": "biome format --write",
		"scn:add": "pnpx shadcn-ui@latest add"
	},
	"dependencies": {
		"@radix-ui/react-slot": "1.2.2",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"isbot": "5.1.27",
		"lodash-es": "4.17.21",
		"lucide-react": "0.509.0",
		"ofetch": "1.4.1",
		"react": "rc",
		"react-dom": "rc",
		"react-router": "^7.0.0",
		"tailwind-merge": "3.2.0",
		"tailwindcss-animate": "1.0.7",
		"valibot": "1.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@cloudflare/vite-plugin": "1.0.12",
		"@cloudflare/workers-types": "4.20250425.0",
		"@react-router/dev": "^7.0.0",
		"@react-router/fs-routes": "7.6.0",
		"@tailwindcss/postcss": "4.1.6",
		"@tailwindcss/vite": "4.1.6",
		"@types/lodash-es": "4.17.12",
		"@types/react": "npm:types-react@rc",
		"@types/react-dom": "npm:types-react-dom@rc",
		"nx": "20.8.1",
		"postcss": "8.5.3",
		"prettier": "3.5.3",
		"tailwindcss": "4.1.6",
		"typescript": "5.8.3",
		"unplugin-auto-import": "19.2.0",
		"vite": "6.3.5",
		"vite-tsconfig-paths": "5.1.4",
		"wrangler": "4.13.2"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3"
		],
		"overrides": {
			"@types/react": "$@types/react",
			"@types/react-dom": "$@types/react-dom"
		}
	},
	"packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39",
	"nx": {
		"targets": {
			"deploy": {
				"dependsOn": [
					"build"
				]
			},
			"start": {
				"dependsOn": [
					"build"
				]
			}
		}
	}
}
